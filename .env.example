DB_USERNAME=root
DB_PASSWORD=

# Police OpenAPI service keys
POLICE_LOST_ITEM_SERVICE_KEY=
POLICE_FOUND_ITEM_SERVICE_KEY=

# Safe182 missing alert OpenAPI
SAFE182_AMBER_LIST_URL=https://www.safe182.go.kr/api/lcm/amberList.do
SAFE182_ESNTL_ID=
SAFE182_AUTH_KEY=
SAFE182_MISSING_ALERT_SYNC_ENABLED=false
SAFE182_MISSING_ALERT_BACKFILL_ON_STARTUP=false
SAFE182_MISSING_ALERT_BACKFILL_LOOKBACK_DAYS=1
SAFE182_MISSING_ALERT_INCREMENTAL_LOOKBACK_DAYS=7
SAFE182_MISSING_ALERT_NUM_OF_ROWS=100

# Police lost-item sync
POLICE_LOST_ITEM_BACKFILL_LOOKBACK_DAYS=1
POLICE_LOST_ITEM_INCREMENTAL_LOOKBACK_DAYS=30

# Police found-item sync
POLICE_FOUND_ITEM_BACKFILL_LOOKBACK_DAYS=1
POLICE_FOUND_ITEM_INCREMENTAL_LOOKBACK_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Naver OAuth
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Kakao OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Seed/import scripts
SEED_DB_PASSWORD=
DEV_DB_PASSWORD=

# Animal Protection API Configuration (농림축산식품부 농림축산검역본부_국가동물보호정보시스템 구조동물 조회 서비스)
# 공공데이터포털에서 발급받은 일반 인증키를 입력해 주세요.
ANIMAL_PROTECTION_SERVICE_KEY=
ANIMAL_PROTECTION_SYNC_ENABLED=false
ANIMAL_PROTECTION_BACKFILL_ON_STARTUP=false
ANIMAL_PROTECTION_BACKFILL_LOOKBACK_DAYS=30
ANIMAL_PROTECTION_INCREMENTAL_LOOKBACK_DAYS=7
ANIMAL_PROTECTION_NUM_OF_ROWS=100

# Animal Loss API Configuration (농림축산식품부 농림축산검역본부_국가동물보호정보시스템 분실신고동물 조회 서비스)
# 공공데이터포털에서 발급받은 일반 인증키를 입력해 주세요.
ANIMAL_LOSS_SERVICE_KEY=
ANIMAL_LOSS_SYNC_ENABLED=false
ANIMAL_LOSS_BACKFILL_ON_STARTUP=false
ANIMAL_LOSS_BACKFILL_LOOKBACK_DAYS=30
ANIMAL_LOSS_INCREMENTAL_LOOKBACK_DAYS=7
ANIMAL_LOSS_NUM_OF_ROWS=100
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:8080
